# Copy to .env and fill in real values. Never commit .env.

# ---- LLM provider ----
OPENROUTER_API_KEY=

# ---- Search / scraping ----
EXA_API_KEY=

# ---- Database ----
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_DB=synapse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://synapse:synapse@postgres:5432/synapse

# ---- Cache / queue ----
REDIS_URL=redis://redis:6379/0

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Required. Generate with: openssl rand -hex 32
JWT_SECRET=
# Local dev runs over plain HTTP; set true in any HTTPS-served environment.
COOKIE_SECURE=false
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# ---- Frontend dev proxy ----
# Target for the Vite dev server proxy (used by vite.config.ts, not the browser bundle).
# When running outside docker, keep this pointing at localhost. docker-compose
# overrides this automatically to http://backend:8000.
API_PROXY_TARGET=http://localhost:8000
